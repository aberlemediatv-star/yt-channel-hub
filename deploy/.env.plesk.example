# =============================================================================
# Plesk / MariaDB — vollstaendige .env-Vorlage
#
# 1. Kopiere nach  laravel/.env
# 2. Passe die Werte an (insbesondere APP_KEY, APP_URL, DB_*, INTERNAL_TOKEN)
# 3. Fuehre aus:  cd laravel && php artisan key:generate
# 4. Fuehre aus:  deploy/plesk-deploy.sh
# =============================================================================

APP_NAME="YT Channel Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ihre-domain.tld

# Pflicht: schuetzt Admin-/Sync-Routen (langer zufaelliger String)
# Erzeugen: php -r "echo bin2hex(random_bytes(32));"
INTERNAL_TOKEN=

APP_LOCALE=de
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Produktion: warning oder error; Debugging: info oder debug
LOG_LEVEL=warning

# --- MariaDB (Plesk) -------------------------------------------------------
# Plesk legt DB + User ueber das Hosting-Panel an.
# Host ist typisch localhost; bei externem DB-Server IP eintragen.
DB_CONNECTION=mariadb
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=yt_hub
DB_USERNAME=yt_hub
DB_PASSWORD=
# Plesk nutzt oft Sockets — ggf. aktivieren:
# DB_SOCKET=/var/lib/mysql/mysql.sock

DB_QUEUE_CONNECTION=mariadb
DB_QUEUE_TABLE=laravel_jobs

# --- Session / Cache / Queue ------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=file
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail -------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ihre-domain.tld"
MAIL_FROM_NAME="${APP_NAME}"

# --- TMDB (optional, fuer Advanced Feeds) -----------------------------------
# Alternativ im Admin unter /admin/api-keys hinterlegbar (DB hat Vorrang).
# TMDB_API_KEY=

# --- Google (optional, falls nicht im Admin hinterlegt) ---------------------
# Alternativ im Admin unter /admin/api-keys hinterlegbar (DB hat Vorrang).
# GOOGLE_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://ihre-domain.tld/oauth_callback.php

# --- Vite -------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Cron-Jobs (in Plesk unter "Geplante Aufgaben" anlegen):
#
#   * * * * *   cd /var/www/vhosts/example.com/httpdocs && php laravel/artisan schedule:run >> /dev/null 2>&1
#   */5 * * * * cd /var/www/vhosts/example.com/httpdocs && php bin/worker.php >> /dev/null 2>&1
#
# =============================================================================
