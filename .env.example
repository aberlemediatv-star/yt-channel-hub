# =============================================================================
# Laravel .env — Produktionswerte (Plesk / Bare-Metal / Docker)
#
# Kopiere diese Datei nach .env und passe die Werte an.
# Fuer Plesk-spezifische Hinweise siehe deploy/.env.plesk.example
# =============================================================================

APP_NAME="YT Channel Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ihre-domain.tld

# Interner Admin-Token (Pflicht: schuetzt Admin-/Sync-Routen)
INTERNAL_TOKEN=

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Datenbank (MariaDB) ---------------------------------------------------
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=yt_hub
DB_USERNAME=yt_hub
DB_PASSWORD=
# DB_SOCKET=/var/lib/mysql/mysql.sock

# Queue-Tabelle (Laravel-Jobs, getrennt von Legacy-jobs-Tabelle)
DB_QUEUE_CONNECTION=mariadb
DB_QUEUE_TABLE=laravel_jobs

# --- Session / Cache / Queue ------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=file

# Oeffentliche Startseite: Laravel-Cache fuer HTML-Datenblock (Sekunden, 0 = aus). Siehe config/ythub.php
PUBLIC_HOME_CACHE_TTL=0

QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (optional) -------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ihre-domain.tld"
MAIL_FROM_NAME="${APP_NAME}"

# --- Cloud-Import (Staff-Upload: Google Drive, Dropbox, optional S3) -------
# Eigene OAuth-Clients (nicht die YouTube-Client-ID).
# Exakte Redirect-URIs (mit Ihrem APP_URL) siehe: docs/MANUAL_CLOUD_IMPORT.md
# Kurzform:
#   {APP_URL}/staff/oauth/gdrive/callback
#   {APP_URL}/staff/oauth/dropbox/callback
# CLOUD_IMPORT_GDRIVE_CLIENT_ID=
# CLOUD_IMPORT_GDRIVE_CLIENT_SECRET=
# CLOUD_IMPORT_DROPBOX_APP_KEY=
# CLOUD_IMPORT_DROPBOX_APP_SECRET=
#
# S3 (AWS oder MinIO): CLOUD_IMPORT_S3_ENABLED=true + Zugangsdaten
# CLOUD_IMPORT_S3_ENABLED=false
# CLOUD_IMPORT_S3_KEY=
# CLOUD_IMPORT_S3_SECRET=
# CLOUD_IMPORT_S3_REGION=us-east-1
# CLOUD_IMPORT_S3_BUCKET=
# CLOUD_IMPORT_S3_PREFIX=
# CLOUD_IMPORT_S3_ENDPOINT=
# CLOUD_IMPORT_S3_USE_PATH_STYLE=false

# --- TMDB (optional, fuer Advanced Feeds) -----------------------------------
# TMDB_API_KEY=

# --- Vite -------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
