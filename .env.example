# Kopie nach .env im Projektroot (nicht committen)

# Datenbank (optional — überschreibt config/config.php)
# DB_DSN=mysql:host=localhost;port=3306;dbname=yt_hub;charset=utf8mb4
# DB_USER=yt_hub_user
# DB_PASSWORD=

# Google (optional)
# GOOGLE_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://ihre-domain.tld/oauth_callback.php

# Interner Zugriffsschutz (sync_*, oauth_start, Backend im Browser)
INTERNAL_TOKEN=

# Optional: OAuth-Refresh-Tokens in DB verschlüsseln (langer zufälliger String, z. B. openssl rand -hex 32)
APP_ENCRYPTION_KEY=

# Admin-Web (public/admin/) — Passwort-Hash: php -r "echo password_hash('IhrPasswort', PASSWORD_DEFAULT);"
ADMIN_PASSWORD_HASH=
# Optional (z. B. Docker/Compose): gleicher Hash als Base64 ohne $-Zeichen
# ADMIN_PASSWORD_HASH_B64=

# Log-Level: DEBUG, INFO, NOTICE, WARNING, ERROR (Produktion: WARNING)
LOG_LEVEL=DEBUG

# Optional: bin/backup_analytics.php — Zeitraum (Tage) und Anzahl aufzubewahrender Backup-Paare (Excel+SAP)
# BACKUP_ANALYTICS_DAYS=30
# BACKUP_RETENTION_FILES=40
